{
  "$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              [
                ":PACKAGE:",
                ":NODE:",
                ":PACKAGE_WITH_PROTOCOL:",
                ":BUN:",
                "!@app/**",
                "!@pages/**",
                "!@widgets/**",
                "!@features/**",
                "!@shared/**",
                "!@lib/**",
                "!@i18n",
                "!@ui/**"
              ],
              ":BLANK_LINE:",
              [":ALIAS:", "@/**"],
              "@app/**",
              ":BLANK_LINE:",
              "@pages/**",
              ":BLANK_LINE:",
              "@widgets/**",
              ":BLANK_LINE:",
              "@features/**",
              ":BLANK_LINE:",
              "@shared/**",
              "@lib/**",
              "@i18n",
              ":BLANK_LINE:",
              "@ui/**",
              ":BLANK_LINE:",
              ":PATH:"
            ]
          }
        },
        "recommended": true,
        "useSortedAttributes": "on",
        "useSortedInterfaceMembers": "on",
        "useSortedKeys": "on",
        "useSortedProperties": "on"
      }
    },
    "enabled": true,
    "includes": ["src/**/*"]
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "files": {
    "ignoreUnknown": false
  },
  "formatter": {
    "attributePosition": "multiline",
    "bracketSpacing": true,
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "always",
      "bracketSameLine": false,
      "bracketSpacing": true,
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "a11y": "info",
      "complexity": {
        "noExcessiveLinesPerFunction": "off"
      },
      "correctness": {
        "useImportExtensions": "off"
      },
      "nursery": "off",
      "performance": {
        "noBarrelFile": "off"
      },
      "recommended": true,
      "security": {
        "noDangerouslySetInnerHtml": "info"
      },
      "style": {
        "useConsistentArrowReturn": "off"
      },
      "suspicious": {
        "noConsole": "info"
      }
    }
  },
  "vcs": {
    "enabled": false
  }
}
